# Docker Compose 環境
NEXT_PUBLIC_LIFF_ID=dev
# 瀏覽器 client fetch 用相對路徑即可（走 nginx 同源）
# 用 http://nginx/api 只有 Docker 內部 SSR 端解析得到，client 會 DNS 失敗。
# 版本前綴 /v1 也必須帶，否則 nginx location 不 match。
NEXT_PUBLIC_API_BASE_URL=/api/v1
# LINE 官方帳號 (OA) 加好友連結；空值 = 跳過 friendship check（local dev 若 LIFF
# channel 沒綁 OA 時用）。正式環境填 https://lin.ee/xxxxxxx 或 https://line.me/R/ti/p/@{basicID}。
NEXT_PUBLIC_LINE_OA_URL=
# Google SSO — OAuth Web Client ID from Google Cloud Console
# （與 auth_service 的 GOOGLE_CLIENT_ID 填同一個值；空字串 = 前端不顯示 Google 按鈕）
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
