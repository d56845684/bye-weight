# main_service 正式環境 — 部署到 VM 時複製為 .env
# hostname 指向 Docker Compose 內部 service name

APP_DATABASE_URL=postgresql+asyncpg://user:CHANGE_ME@cloudsql_proxy:5432/app_db
REDIS_URL=redis://redis:6379/0
AUTH_SERVICE_URL=http://auth_service:8001
INTERNAL_SERVICE_TOKEN=CHANGE_ME_USE_openssl_rand_hex_32
LINE_CHANNEL_SECRET=CHANGE_ME
LINE_CHANNEL_ACCESS_TOKEN=CHANGE_ME
LIFF_ID=CHANGE_ME
GEMINI_API_KEY=CHANGE_ME
GCS_BUCKET_NAME=CHANGE_ME
GCP_PROJECT_ID=CHANGE_ME
ENVIRONMENT=production
