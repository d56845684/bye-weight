# Docker Compose 環境（hostname = service name）
APP_DATABASE_URL=postgresql+asyncpg://postgres:dev@postgres:5432/app_db
REDIS_URL=redis://redis:6379/0
# service-to-service：LINE webhook 呼叫 auth_service 的 /auth/internal/* 反查 user
AUTH_SERVICE_URL=http://auth_service:8001
INTERNAL_SERVICE_TOKEN=CHANGE_ME
LINE_CHANNEL_SECRET=dev
LINE_CHANNEL_ACCESS_TOKEN=dev
LIFF_ID=dev
GEMINI_API_KEY=dev
GCS_BUCKET_NAME=dev
GCP_PROJECT_ID=dev
ENVIRONMENT=development
