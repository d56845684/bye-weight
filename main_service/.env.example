# main_service 環境變數
# 複製此檔為 .env 並填入實際值
# cp .env.example .env

# ── 本機開發用 localhost，Docker 裡用 postgres ──
# port 5433/6380 避免與 teaching-platform 衝突
APP_DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5433/app_db
REDIS_URL=redis://localhost:6380/0

# ── LINE ──
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LIFF_ID=

# ── Gemini AI ──
GEMINI_API_KEY=

# ── GCS ──
GCS_BUCKET_NAME=
GCP_PROJECT_ID=

# ── 環境 ──
ENVIRONMENT=development
