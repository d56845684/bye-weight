# auth_service 環境變數
# 複製此檔為 .env 並填入實際值
# cp .env.example .env

# ── 本機開發用 localhost，Docker 裡用 postgres ──
# port 5433/6380 避免與 teaching-platform 衝突
AUTH_DATABASE_URL=postgres://postgres:dev@localhost:5433/auth_db?sslmode=disable
REDIS_URL=redis://localhost:6380/0

# ── JWT ──
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
ACCESS_TOKEN_EXPIRE=900
REFRESH_TOKEN_EXPIRE=604800

# ── LINE ──
LINE_CHANNEL_SECRET=

# ── Google OAuth（營養師 / 管理員登入）──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── 環境 ──
ENV=development

# ── Service-to-service shared secret（/auth/internal/*）──
# main_service 的 LINE webhook 等情境沒有 user JWT，改帶這個 header 反查 user。
# 空字串 → internal endpoints 一律 401 fail-close。
INTERNAL_SERVICE_TOKEN=
