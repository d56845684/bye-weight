# auth_service 環境變數
# 複製此檔為 .env 並填入實際值
# cp .env.example .env

# ── 本機開發用 localhost，Docker 裡用 postgres ──
# port 5433/6380 避免與 teaching-platform 衝突
AUTH_DATABASE_URL=postgres://postgres:dev@localhost:5433/auth_db?sslmode=disable
REDIS_URL=redis://localhost:6380/0

# ── JWT ──
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
ACCESS_TOKEN_EXPIRE=900
REFRESH_TOKEN_EXPIRE=604800

# ── LINE ──
LINE_CHANNEL_SECRET=
# Messaging API channel access token — /auth/line-friendship-check 打 LINE
# /v2/bot/profile 查 user 是否為 OA follower。空字串 → is_friend=null。
LINE_CHANNEL_ACCESS_TOKEN=

# ── Google OAuth（營養師 / 管理員登入）──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── 環境 ──
ENV=development

# ── Service-to-service shared secret（/auth/internal/*）──
# main_service 的 LINE webhook 等情境沒有 user JWT，改帶這個 header 反查 user。
# 空字串 → internal endpoints 一律 401 fail-close。
INTERNAL_SERVICE_TOKEN=

# ── Dev super_admin 預設密碼 ──
# 啟動時以此覆蓋 dev-admin 的 password identity（bcrypt 後寫 auth_identities）。
# Password 空字串 → 略過不動 DB；production 建議留空。
SUPER_ADMIN_EMAIL=admin@dev.local
SUPER_ADMIN_PASSWORD=
