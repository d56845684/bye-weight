# auth_service 正式環境 — 部署到 VM 時複製為 .env
# hostname 指向 Docker Compose 內部 service name

AUTH_DATABASE_URL=postgres://user:CHANGE_ME@cloudsql_proxy:5432/auth_db
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE=900
REFRESH_TOKEN_EXPIRE=604800
LINE_CHANNEL_SECRET=CHANGE_ME
LINE_CHANNEL_ACCESS_TOKEN=CHANGE_ME
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
ENV=production
INTERNAL_SERVICE_TOKEN=CHANGE_ME_USE_openssl_rand_hex_32
# Production: 建議留空（關閉 seed-from-env，super_admin 走 SSO 或手動設密碼）
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
