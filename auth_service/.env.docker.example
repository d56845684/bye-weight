# Docker Compose 環境（hostname = service name）
AUTH_DATABASE_URL=postgres://postgres:dev@postgres:5432/auth_db?sslmode=disable
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
ACCESS_TOKEN_EXPIRE=900
REFRESH_TOKEN_EXPIRE=604800
LINE_CHANNEL_SECRET=dev
# Messaging API channel access token — /auth/line-friendship-check 打 LINE
# /v2/bot/profile 判 user 是否已 follow OA。空字串 → is_friend=null degrade。
LINE_CHANNEL_ACCESS_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ENV=development
# Shared secret for /auth/internal/*（LINE webhook 等服務對服務呼叫）。
# 空字串 → internal endpoints 一律 401 fail-close。
INTERNAL_SERVICE_TOKEN=CHANGE_ME
